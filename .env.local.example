# Copy this file to .env.local and fill in your Supabase project's values.
# Find these in your Supabase dashboard: Project Settings -> API.
# Never commit .env.local or paste these keys into chat.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# SMS gateway (optional). Leave everything below unset to use the manual
# workflow on the Messages page: export pending messages as CSV for a
# bulk-SMS portal, then mark them sent.
#
# Pick ONE provider; the Messages page then shows a "Send via …" button.
# Numbers are normalized to E.164 before sending (0617… -> +252617…).
# ---------------------------------------------------------------------------
# SMS_PROVIDER=twilio | africastalking | http
# SMS_DEFAULT_COUNTRY_CODE=+252

# Twilio (TWILIO_FROM is a phone number, or a Messaging Service SID "MG…"):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# Africa's Talking:
# AT_USERNAME=
# AT_API_KEY=
# AT_FROM=            # optional sender id

# Generic HTTP gateway (local providers like Hormuud/Somtel — a POST with
# {to} and {message} substituted into the body template):
# SMS_HTTP_URL=https://gateway.example.com/send
# SMS_HTTP_HEADERS={"Authorization":"Bearer …"}
# SMS_HTTP_BODY={"to":"{to}","message":"{message}"}

# ---------------------------------------------------------------------------
# Scheduled delivery (optional): GET /api/notifications/send with header
# "Authorization: Bearer $CRON_SECRET" delivers every school's pending
# messages — point Vercel Cron or any scheduler at it. Requires both:
# ---------------------------------------------------------------------------
# CRON_SECRET=a-long-random-string
# SUPABASE_SERVICE_ROLE_KEY=   # Project Settings -> API (keep this secret!)
